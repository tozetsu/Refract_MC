{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Refract",
  "version": "1.2.0",
  "identifier": "com.refract",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm dev:real",
    "beforeBuildCommand": "pnpm build:real"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Refract",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://localhost:* ws://localhost:* https:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/RefractMC/Refract_MC/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMTAxQzkwRjU0N0JBMjQKUldRa3VrZjFrQndRLzg2aXZKRXY3NVNxalRZNjlhL3lnRjhIUGI5WlhOd1FvaStBMkwvZFk4NzUK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
